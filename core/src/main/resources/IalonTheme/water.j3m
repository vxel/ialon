// Texture-sourcing container for the "water" block type (see Blocks/MatDefs/BlockSource.j3md). Provides
// the water diffuse image for the block TextureArray ; flowing water renders (with scroll) from that
// array via Blocks/Materials/water-array.j3m, not from this material.
Material water-still : Blocks/MatDefs/BlockSource.j3md {

    MaterialParameters {
        DiffuseMap: Flip WrapRepeat_S WrapRepeat_T IalonTheme/water_calm.png
    }

}
