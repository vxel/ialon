// Texture-sourcing container for block types (see Blocks/MatDefs/BlockSource.j3md). The DiffuseMap is a
// placeholder replaced per type by the theme loader ; the image feeds the block TextureArray. Blocks
// render from that array via default-block-array.j3m, not from this material.
Material normal-block : Blocks/MatDefs/BlockSource.j3md {

    MaterialParameters {
        DiffuseMap: Flip MagBilinear BilinearNearestMipMap IalonTheme/dummy.png
    }

}
